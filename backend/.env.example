# === Katabatic Backend — Environment Variables ===
# Copy this to .env and fill in your keys

# LLM APIs (required for scoring engine + narratives)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Weather data (required for weather pipeline)
NOAA_API_TOKEN=

# On-chain data (required for mint/burn cross-reference)
ETHERSCAN_API_KEY=

# IPFS pinning (required for score verification layer)
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Server config
HOST=0.0.0.0
PORT=8000
